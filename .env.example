# Frontend public config only. NEVER put seed phrase or private key here.
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Public wallet addresses, comma-separated.
VITE_INITIAL_MANAGERS=0xManagerWalletHere
VITE_INITIAL_TECHNICIANS=0xTechWallet1,0xTechWallet2,0xTechWallet3,0xTechWallet4,0xTechWallet5

# Optional display names, comma-separated. Use foreign/demo names for pitch/demo.
VITE_MANAGER_NAMES=Ethan Brooks
VITE_TECHNICIAN_NAMES=Liam Carter,Noah Bennett,Oliver Reed,Lucas Morgan,Mason Clark

# demo = MetaMask signs actions and browser stores state.
# contract = calls deployed Sepolia contract if VITE_CONTRACT_ADDRESS is set.
VITE_APP_MODE=demo

# Optional: set this to the block where the contract was deployed for faster event sync.
# If unknown, leave 0; the app will scan recent Sepolia blocks.
VITE_CONTRACT_DEPLOY_BLOCK=0

# Optional RPC URL used by Zama Relayer SDK. Do not put private keys here.
VITE_RELAYER_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
